\" />\n        <el-table-column prop=\"level\" label=\"级别\" width=\"100\">\n          <template #default=\"{ row }\">\n            <el-tag :type=\"getLevelTagType(row.level)\">{{ row.level }}级</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"status\" label=\"状态\" width=\"120\">\n          <template #default=\"{ row }\">\n            <el-tag :type=\"getStatusTagType(row.status)\">{{ getStatusText(row.status) }}</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"createdAt\" label=\"创建时间\" width=\"150\" />\n        <el-table-column label=\"操作\" width=\"150\" fixed=\"right\">\n          <template #default>\n            <el-button link type=\"primary\" size=\"small\">编辑</el-button>\n            <el-button link type=\"danger\" size=\"small\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { Search } from '@element-plus/icons-vue'\n\ndefinePageMeta({ middleware: 'auth' })\n\nconst crmStore = useCrmStore()\nconst searchQuery = ref('')\n\nonMounted(() => {\n  crmStore.fetchCustomers()\n})\n\nconst filteredCustomers = computed(() => {\n  if (!searchQuery.value) return crmStore.customers\n  return crmStore.customers.filter(c => c.name.includes(searchQuery.value))\n})\n\nconst getLevelTagType = (level: string) => {\n  const map: Record<string, 'danger' | 'warning' | 'info' | 'primary'> = {\n    'A': 'danger',\n    'B': 'warning',\n    'C': 'info',\n    'D': 'primary'\n  }\n  return map[level] || 'info'\n}\n\nconst getStatusTagType = (status: string) => {\n  const map: Record<string, 'success' | 'danger' | 'warning' | 'info'> = {\n    'active': 'success',\n    'inactive': 'danger',\n    'potential': 'warning'\n  }\n  return map[status] || 'info'\n}\n\nconst getStatusText = (status: string) => {\n  const map: Record<string, string> = {\n    'active': '活跃',\n    'inactive': '流失',\n    'potential': '潜在'\n  }\n  return map[status] || status\n}\n</script>\n\n<style scoped>\n.header-actions {\n  display: flex;\n  align-items: center;\n}\n</style>"],"version":3}