0BAAgCF,gBAAAC,gBAAA,aAAA,IAAA,KAAA,CAAA,GAAA,CAAA;AAAA,wBAAJ,CAAA;AAAA;;;;;;oBAOtD,MAAA;AAAA,oBAJI,OAAA;AAAA,oBAAoB,OAAA;AAAA,kBAAa,GAAA;AAAA;sBAC5BC,YAAA,wBAAA;AAAA,wBACoE,YAAA,IAAA;AAAA,wBAA7D,OAAA,oBAAA,IAAA,WAAA;AAAA,sBAAwD,GAAA,MAAA,GAAA,CAAA,cAAA,OAAA,CAAA;AAAA;;;;oBAGlC,MAAA;AAAA,oBAAlC,OAAA;AAAA,oBAAc,OAAA;AAAA,kBAAY,CAAA;AAAA;oBACuB,MAAA;AAAA,oBAAjD,OAAA;AAAA,oBAA0B,OAAA;AAAA,kBAAe,CAAA;AAAA;oBAM7C,OAAA;AAAA,oBALK,OAAA;AAAA,oBAAW,OAAA;AAAA,kBAAY,GAAA;AAAA;sBAEgBA,YAAA,sBAAA;AAAA,wBAAA,MAAA;AAAA,wBAA/C,MAAA;AAAA,wBAAU,MAAA;AAAA,sBAAe,GAAA;AAAA;0BAAUF,gBAAA,IAAA;AAAA,wBAAA,CAAA;AAAA;;;wBACY,MAAA;AAAA,wBAA/C,MAAA;AAAA,wBAAU,MAAA;AAAA,sBAAe,GAAA;AAAA;0BAAUA,gBAAA,IAAA;AAAA,wBAAA,CAAA;AAAA;;;;;;;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderComponent","_withCtx","_createTextVNode","_toDisplayString","_createVNode","_unref"],"sources":["../../../../pages/opportunities.vue"],"sourcesContent":["<template>\n  <div class=\"opportunities-container\">\n    <div class=\"page-header\">\n      <h2 class=\"page-title\">商机管理</h2>\n      <el-button type=\"primary\">新建商机</el-button>\n    </div>\n\n    <el-card>\n      <el-table :data=\"crmStore.opportunities\" style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"序号\" width=\"80\" />\n        <el-table-column prop=\"name\" label=\"商机名称\" min-width=\"180\" />\n        <el-table-column prop=\"customer\" label=\"客户\" min-width=\"180\" />\n        <el-table-column prop=\"amount\" label=\"金额\" width=\"120\">\n          <template #default=\"{ row }\">\n            {{ formatAmount(row.amount) }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"stage\" label=\"阶段\" width=\"120\">\n          <template #default=\"{ row }\">\n            <el-tag :type=\"getStageTagType(row.stage)\">{{ getStageText(row.stage) }}</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"probability\" label=\"赢单概率\" width=\"150\">\n          <template #default=\"{ row }\">\n            <el-progress :percentage=\"row.probability\" :color=\"getProbabilityColor(row.probability)\" />\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"owner\" label=\"负责人\" width=\"120\" />\n        <el-table-column prop=\"expectedCloseDate\" label=\"预计关闭日期\" width=\"150\" />\n        <el-table-column label=\"操作\" width=\"120\" fixed=\"right\">\n          <template #default>\n            <el-button link type=\"primary\" size=\"small\">查看</el-button>\n            <el-button link type=\"primary\" size=\"small\">推进</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({ middleware: 'auth' })\n\nconst crmStore = useCrmStore()\n\nonMounted(() => {\n  crmStore.fetchOpportunities()\n})\n\nconst formatAmount = (amount: number) => {\n  return new Intl.NumberFormat('zh-CN', { style: 'currency', currency: 'CNY', maximumFractionDigits: 0 }).format(amount)\n}\n\nconst getStageTagType = (stage: string) => {\n  const map: Record<string, 'info' | 'primary' | 'warning' | 'primary' | 'success' | 'danger'> = {\n    'prospecting': 'info',\n    'qualification': 'primary',\n    'proposal': 'warning',\n    'negotiation': 'primary',\n    'closed_won': 'success',\n    'closed_lost': 'danger'\n  }\n  return map[stage] || 'info'\n}\n\nconst getStageText = (stage: string) => {\n  const map: Record<string, string> = {\n    'prospecting': '初期沟通',\n    'qualification': '立项评估',\n    'proposal': '方案报价',\n    'negotiation': '商务谈判',\n    'closed_won': '赢单',\n    'closed_lost': '输单'\n  }\n  return map[stage] || stage\n}\n\nconst getProbabilityColor = (percentage: number) => {\n  if (percentage < 30) return '#909399'\n  if (percentage < 70) return '#E6A23C'\n  if (percentage < 100) return '#409EFF'\n  return '#67C23A'\n}\n</script>"],"version":3}